{
  "name": "winemall-server",
  "version": "1.0.0",
  "private": true,
  "description": "优选商城后端服务 - NestJS",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "db:migrate": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/database/data-source.ts migration:run",
    "db:revert": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/database/data-source.ts migration:revert",
    "db:gen": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/database/data-source.ts migration:generate",
    "db:create": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/database/data-source.ts migration:create",
    "db:show": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/database/data-source.ts migration:show",
    "db:seed": "ts-node -r tsconfig-paths/register src/database/seeds/index.ts",
    "db:create-database": "ts-node -r tsconfig-paths/register src/database/scripts/create-database.ts",
    "db:migrate:local": "cross-env DOTENV_FILE=.env.local ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/database/data-source.ts migration:run",
    "db:revert:local": "cross-env DOTENV_FILE=.env.local ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/database/data-source.ts migration:revert",
    "db:show:local": "cross-env DOTENV_FILE=.env.local ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/database/data-source.ts migration:show",
    "db:seed:local": "cross-env DOTENV_FILE=.env.local ts-node -r tsconfig-paths/register src/database/seeds/index.ts",
    "db:create-database:local": "cross-env DOTENV_FILE=.env.local ts-node -r tsconfig-paths/register src/database/scripts/create-database.ts",
    "verify:local": "cross-env DOTENV_FILE=.env.local ts-node -r tsconfig-paths/register src/database/scripts/verify-connections.ts",
    "db:reset-menus:local": "cross-env DOTENV_FILE=.env.local ts-node -r tsconfig-paths/register src/database/scripts/reset-menus.ts",
    "start:dev:local": "cross-env DOTENV_FILE=.env.local nest start --watch"
  },
  "dependencies": {
    "@casl/ability": "^6.7.1",
    "@nestjs/bull": "^10.2.1",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/typeorm": "^10.0.2",
    "bcrypt": "^5.1.1",
    "bull": "^4.16.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "ioredis": "^5.4.1",
    "minio": "^8.0.1",
    "mysql2": "^3.11.3",
    "nestjs-pino": "^4.1.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.2.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.2.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.4",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
