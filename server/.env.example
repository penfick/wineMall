# ===== 应用 =====
NODE_ENV=development
APP_PORT=3000
APP_PREFIX=v1
TIMEZONE=+08:00
LOG_LEVEL=debug

# ===== 数据库 =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=wineMall@2026
DB_NAME=wine_mall
DB_LOGGING=false

# ===== Redis =====
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== MinIO =====
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123456
